{
  "name": "ls-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "dev:watch": "tsx watch src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build && npm run build:server",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=esm --outfile=dist/server/index.mjs --packages=external",
    "build:capture:x": "esbuild src/capture/xLiveCaptureAgent.ts --bundle --platform=node --format=esm --outfile=dist/capture/xLiveCaptureAgent.mjs --packages=external",
    "start": "node dist/server/index.mjs",
    "capture:x": "npm run build:capture:x && node dist/capture/xLiveCaptureAgent.mjs",
    "test": "vitest run --passWithNoTests=false",
    "test:watch": "vitest",
    "verify": "npm run test && npm run build"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.12.3",
    "tsx": "^4.19.2",
    "vite": "^8.0.16",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.20",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
