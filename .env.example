PORT=4200
# Public-only mode redirects / to /live and disables admin/OAuth/settings APIs.
# Use this when deploying the viewer hub from upfront env config instead of an admin dashboard.
PUBLIC_LIVE_ONLY=false
# Optional operator password for the admin dashboard and admin APIs.
# Leave empty for local development. Set before exposing / outside localhost.
ADMIN_PASSWORD=
# Long random value used to sign the operator session cookie. Falls back to SESSION_SECRET if set.
ADMIN_SESSION_SECRET=
ADMIN_SESSION_COOKIE=mb_operator_session
ADMIN_SESSION_MAX_AGE_SECONDS=86400
# Use lax for normal Market Bubble hosting. Use none only for cross-site HTTPS admin embedding, which is not recommended.
ADMIN_SESSION_SAME_SITE=lax
# Comma-separated origins allowed to iframe /live and /embed. The app always includes 'self'.
EMBED_ALLOWED_ORIGINS=https://marketbubble.com,https://www.marketbubble.com
# Comma-separated public dev hosts allowed by Vite middleware, for example:
# DEV_ALLOWED_HOSTS=your-ngrok-domain.ngrok-free.dev
# Kick redirect/webhook hosts are also allowed automatically when set below.
DEV_ALLOWED_HOSTS=
# Optional public dev base URL for Vite hot reload through ngrok/tunnels, for example:
# DEV_PUBLIC_URL=https://your-ngrok-domain.ngrok-free.dev
DEV_PUBLIC_URL=
CHAT_HISTORY_LIMIT=500
VIEWER_POLL_MS=30000
# Server-side BetterTTV cache TTL. Keeps viewer browsers from calling BetterTTV directly.
BETTERTTV_CACHE_TTL_MS=600000
DEMO_CHAT_ENABLED=true
# Real integrations auto-disable demos. Set this to true only when you intentionally want both.
DEMO_CHAT_FORCE=false

# Native public dashboard. Configure the embed URL for the stream player shown at /live.
MARKETBUBBLE_DASHBOARD_TITLE=Market Bubble Live
MARKETBUBBLE_CHAT_LABEL=Market Bubble
MARKETBUBBLE_STREAM_LABEL=
MARKETBUBBLE_STREAM_EMBED_URL=
MARKETBUBBLE_STREAM_WATCH_URL=
LIVE_SESSION_FILE=.data/live-session.json
# Basic in-memory protection for the native public chat endpoint.
NATIVE_CHAT_RATE_LIMIT=8
NATIVE_CHAT_RATE_WINDOW_MS=10000
# Signed guest sessions for unauthenticated Market Bubble native chat.
# Use a long random value in production so guest identity cookies cannot be forged.
NATIVE_CHAT_SESSION_SECRET=
NATIVE_CHAT_SESSION_COOKIE=mb_native_guest
NATIVE_CHAT_SESSION_MAX_AGE_SECONDS=2592000
# Use lax for same-site hosting such as live.marketbubble.com embedded on marketbubble.com.
# Use none only for cross-site HTTPS iframe hosting; browsers require Secure cookies for SameSite=None.
NATIVE_CHAT_SESSION_SAME_SITE=lax

# Twitch EventSub WebSocket. Local-friendly real Twitch chat retrieval.
TWITCH_EVENTSUB_ENABLED=false
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:4200/api/auth/twitch/callback
TWITCH_OAUTH_SCOPES=user:read:chat
# Local dev OAuth token storage. Keep this ignored; it contains access/refresh tokens.
TWITCH_SESSION_FILE=.data/twitch-session.json
TWITCH_USER_ACCESS_TOKEN=
TWITCH_BROADCASTER_USER_ID=
TWITCH_USER_ID=

# Twitch webhook verification. Required when receiving real EventSub webhook requests.
TWITCH_EVENTSUB_SECRET=

# Kick webhooks. Requires a Kick developer app with a public HTTPS webhook URL.
KICK_AUTO_SUBSCRIBE=false
KICK_INGESTION_ENABLED=true
KICK_WEBHOOK_URL=https://your-public-domain.example/api/webhooks/kick
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_REDIRECT_URI=https://your-public-domain.example/api/auth/kick/callback
KICK_OAUTH_SCOPES=events:subscribe channel:read
# Local dev OAuth token storage. Keep this ignored; it contains access/refresh tokens.
KICK_SESSION_FILE=.data/kick-session.json
# Optional manual app token. If empty, target-channel subscriptions can mint an app token
# from KICK_CLIENT_ID and KICK_CLIENT_SECRET with the client credentials grant.
KICK_ACCESS_TOKEN=
KICK_BROADCASTER_USER_ID=

# Kick webhook verification. Paste Kick's public key PEM when deploying real webhooks.
KICK_PUBLIC_KEY_PEM=

# X Filtered Stream worker. This streams public posts, not first-class livestream chat.
X_STREAM_ENABLED=false
X_BEARER_TOKEN=
X_FILTER_RULES="#yourStreamHashtag|stream hashtag;@yourHandle|broadcaster mention"
# Experimental X livechat browser capture. Uses a visible Chrome/Edge window opened by Market Bubble Live Chat.
X_LIVE_CHAT_CHROME_PATH=
X_LIVE_CHAT_PROFILE_DIR=.data/x-live-chat-profile
X_LIVE_CHAT_DEBUG_PORT=9223
X_LIVE_CHAT_SCAN_MS=1200
# Set true for an env-only/no-admin X demo on a capture machine that can launch Chrome.
# Keep false for hosted deployments or when using the browser extension/bridge.
X_LIVE_CHAT_WORKER_AUTO_START=false
# Optional comma-separated usernames or livechat URLs shown in Connect X Sources.
X_LIVE_CHAT_TARGETS=
# Experimental X broadcast chat browser-capture bridge. No X API credentials required.
X_LIVE_CAPTURE_ALLOWED_ORIGINS=https://x.com,https://twitter.com,https://mobile.x.com,http://localhost:4200,http://127.0.0.1:4200
# Allows requests from the bundled Chrome/Edge extension. Set false to require exact web origins only.
X_LIVE_CAPTURE_ALLOW_EXTENSION_ORIGINS=true
X_LIVE_CAPTURE_TOKEN=
# Operator-side capture agent. Public viewers never run this; use it from a trusted capture machine.
X_LIVE_CAPTURE_ENDPOINT=http://localhost:4200/api/capture/x-live
# Optional override for the capture agent. Falls back to X_LIVE_CHAT_TARGETS.
X_CAPTURE_AGENT_TARGETS=
X_CAPTURE_AGENT_QUEUE_LIMIT=1000
